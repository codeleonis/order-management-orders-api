{
  "info": {
    "name": "Product CRUD",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "CRUD completo para el recurso Product. Base URL configurada mediante la variable de colección `base_url` (default: http://localhost:8080). \n\nEl request **Create Product** guarda automáticamente el ID del producto creado en la variable `product_id`, que los demás requests usan mediante `{{product_id}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "product_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/health",
                  "host": ["{{base_url}}"],
                  "path": ["health"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"status\": \"ok\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('product_id', body.id);",
                  "    pm.test('product_id saved: ' + body.id, () => pm.expect(body.id).to.be.a('string'));",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Widget Pro\",\n  \"description\": \"A high-quality widget for professionals\",\n  \"price\": 29.99,\n  \"sku\": \"WGT-001\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/products",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products"]
            }
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Widget Pro\",\n  \"description\": \"A high-quality widget for professionals\",\n  \"price\": 29.99,\n  \"sku\": \"WGT-001\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/products",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products"]
                }
              },
              "status": "Created",
              "code": 201,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"id\": \"10da2b88-77c1-4bab-b9a0-8f70d378dfb1\",\n  \"name\": \"Widget Pro\",\n  \"description\": \"A high-quality widget for professionals\",\n  \"price\": 29.99,\n  \"sku\": \"WGT-001\",\n  \"created_at\": \"2026-05-04T03:44:21.604291087Z\"\n}"
            },
            {
              "name": "409 Conflict — Duplicate SKU",
              "originalRequest": {
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Another Widget\",\n  \"description\": \"desc\",\n  \"price\": 10.00,\n  \"sku\": \"WGT-001\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/products",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products"]
                }
              },
              "status": "Conflict",
              "code": 409,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"error\": \"product with this SKU already exists\"\n}"
            },
            {
              "name": "422 Unprocessable Entity — Invalid Price",
              "originalRequest": {
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Bad Item\",\n  \"description\": \"desc\",\n  \"price\": -5.00,\n  \"sku\": \"BAD-001\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/products",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products"]
                }
              },
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"error\": \"price must be greater than zero\"\n}"
            }
          ]
        },
        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has pagination fields', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.all.keys('items', 'total', 'page', 'page_size', 'total_pages');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/products?page=1&page_size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "10" }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/api/v1/products?page=1&page_size=10",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "page_size", "value": "10" }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"items\": [\n    {\n      \"id\": \"10da2b88-77c1-4bab-b9a0-8f70d378dfb1\",\n      \"name\": \"Widget Pro\",\n      \"description\": \"A high-quality widget for professionals\",\n      \"price\": 29.99,\n      \"sku\": \"WGT-001\",\n      \"created_at\": \"2026-05-04T03:44:21.604786Z\",\n      \"updated_at\": \"2026-05-04T03:44:21.604786Z\"\n    }\n  ],\n  \"total\": 1,\n  \"page\": 1,\n  \"page_size\": 10,\n  \"total_pages\": 1\n}"
            }
          ]
        },
        {
          "name": "Get Product by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID matches', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.eql(pm.collectionVariables.get('product_id'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/api/v1/products/{{product_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products", "{{product_id}}"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"id\": \"10da2b88-77c1-4bab-b9a0-8f70d378dfb1\",\n  \"name\": \"Widget Pro\",\n  \"description\": \"A high-quality widget for professionals\",\n  \"price\": 29.99,\n  \"sku\": \"WGT-001\",\n  \"created_at\": \"2026-05-04T03:44:21.604786Z\",\n  \"updated_at\": \"2026-05-04T03:44:21.604786Z\"\n}"
            },
            {
              "name": "404 Not Found",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/api/v1/products/00000000-0000-0000-0000-000000000000",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products", "00000000-0000-0000-0000-000000000000"]
                }
              },
              "status": "Not Found",
              "code": 404,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"error\": \"product not found\"\n}"
            }
          ]
        },
        {
          "name": "Update Product (PATCH)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('updated_at is present', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.updated_at).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Widget Pro Max\",\n  \"price\": 49.99\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}"]
            }
          },
          "response": [
            {
              "name": "200 OK — Partial update (name + price)",
              "originalRequest": {
                "method": "PATCH",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Widget Pro Max\",\n  \"price\": 49.99\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/products/{{product_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products", "{{product_id}}"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"id\": \"10da2b88-77c1-4bab-b9a0-8f70d378dfb1\",\n  \"name\": \"Widget Pro Max\",\n  \"description\": \"A high-quality widget for professionals\",\n  \"price\": 49.99,\n  \"sku\": \"WGT-001\",\n  \"updated_at\": \"2026-05-04T03:44:46.096854152Z\"\n}"
            },
            {
              "name": "422 Unprocessable Entity — No fields provided",
              "originalRequest": {
                "method": "PATCH",
                "body": {
                  "mode": "raw",
                  "raw": "{}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/products/{{product_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products", "{{product_id}}"]
                }
              },
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"error\": \"at least one field must be provided\"\n}"
            }
          ]
        },
        {
          "name": "Delete Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}"]
            }
          },
          "response": [
            {
              "name": "204 No Content",
              "originalRequest": {
                "method": "DELETE",
                "url": {
                  "raw": "{{base_url}}/api/v1/products/{{product_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products", "{{product_id}}"]
                }
              },
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            },
            {
              "name": "404 Not Found",
              "originalRequest": {
                "method": "DELETE",
                "url": {
                  "raw": "{{base_url}}/api/v1/products/00000000-0000-0000-0000-000000000000",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "products", "00000000-0000-0000-0000-000000000000"]
                }
              },
              "status": "Not Found",
              "code": 404,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"error\": \"product not found\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
